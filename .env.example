APP_HOST=127.0.0.1
APP_PORT=8788
DATABASE_URL=sqlite:///data/askbot.db

PLAY_DEVELOPER_URL=https://play.google.com/store/apps/dev?id=6396415332355171917
DAILY_POST_TIME=00:00
APP_TIMEZONE=Asia/Karachi
AUTO_PUBLISH_AFTER_QC=true
REQUIRE_IMAGE_ASSET=true
DAILY_VIDEO_TIME=18:00

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

BUFFER_API_KEY=
BUFFER_API_KEY_2=
BUFFER_DEFAULT_MODE=customScheduled

# Creative generation providers — free tiers, no credit card required.
CREATIVE_IMAGE_PROVIDER=gemini
# Video is disabled by default ("none") because no free video API works
# reliably without an API key in 2026. Set to "zsky" or "pollinations" if
# you have a provider that works.
CREATIVE_VIDEO_PROVIDER=none
CREATIVE_IMAGE_DAILY_LIMIT=3
CREATIVE_VIDEO_DAILY_LIMIT=2

# Gemini image generation (500 free requests/day via Google AI Studio)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ZSky video generation (endpoint currently returns 404; kept for future use)
ZSKY_VIDEO_API_URL=https://zsky.ai/api/v1/video/generate

# Legacy Pollinations provider (video now requires API key as of 2026)
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_VIDEO_MODEL=seedance

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
